# Database
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://v0-idriveu.vercel.app

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps (Places Autocomplete in booking wizard)
# Enable "Places API" at https://console.cloud.google.com/apis/library
# Restrict the key to your domain + Maps JS API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase (Realtime driver location subscriptions)
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
IDRIVEU_WHATSAPP_NUMBER=whatsapp:+27XXXXXXXXX

# Seed
SEED_ADMIN_PASSWORD=change-me-on-first-login
